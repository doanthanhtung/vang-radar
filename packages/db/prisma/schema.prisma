generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Source {
  id                 String              @id @default(uuid()) @db.Uuid
  code               String              @unique
  name               String
  type               String
  baseUrl            String?             @map("base_url")
  priority           Int                 @default(100)
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz
  domesticGoldPrices DomesticGoldPrice[]
  worldGoldPrices    WorldGoldPrice[]
  fxRates            FxRate[]
  macroIndicators    MacroIndicator[]

  @@map("sources")
}

model GoldProduct {
  id                    String                 @id @default(uuid()) @db.Uuid
  code                  String                 @unique
  name                  String
  brand                 String
  category              String
  purity                String?
  unit                  String                 @default("luong")
  isActive              Boolean                @default(true) @map("is_active")
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz
  domesticGoldPrices    DomesticGoldPrice[]
  goldMetrics           GoldMetric[]
  signalSnapshots       SignalSnapshot[]
  portfolioTransactions PortfolioTransaction[]

  @@map("gold_products")
}

model DomesticGoldPrice {
  id            String      @id @default(uuid()) @db.Uuid
  time          DateTime    @db.Timestamptz
  productId     String      @map("product_id") @db.Uuid
  sourceId      String      @map("source_id") @db.Uuid
  buyPriceVnd   Decimal     @map("buy_price_vnd") @db.Decimal(18, 2)
  sellPriceVnd  Decimal     @map("sell_price_vnd") @db.Decimal(18, 2)
  unit          String      @default("luong")
  rawPayload    Json?       @map("raw_payload")
  qualityScore  Decimal     @default(100) @map("quality_score") @db.Decimal(5, 2)
  isValid       Boolean     @default(true) @map("is_valid")
  invalidReason String?     @map("invalid_reason")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  product       GoldProduct @relation(fields: [productId], references: [id])
  source        Source      @relation(fields: [sourceId], references: [id])

  @@unique([productId, sourceId, time])
  @@index([productId, time(sort: Desc)])
  @@index([sourceId, time(sort: Desc)])
  @@index([isValid, time(sort: Desc)])
  @@map("domestic_gold_prices")
}

model WorldGoldPrice {
  id            String   @id @default(uuid()) @db.Uuid
  time          DateTime @db.Timestamptz
  sourceId      String   @map("source_id") @db.Uuid
  symbol        String   @default("XAUUSD")
  priceUsdPerOz Decimal  @map("price_usd_per_oz") @db.Decimal(18, 6)
  bid           Decimal? @db.Decimal(18, 6)
  ask           Decimal? @db.Decimal(18, 6)
  rawPayload    Json?    @map("raw_payload")
  qualityScore  Decimal  @default(100) @map("quality_score") @db.Decimal(5, 2)
  isValid       Boolean  @default(true) @map("is_valid")
  invalidReason String?  @map("invalid_reason")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  source        Source   @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, symbol, time])
  @@index([symbol, time(sort: Desc)])
  @@index([sourceId, time(sort: Desc)])
  @@index([isValid, time(sort: Desc)])
  @@map("world_gold_prices")
}

model FxRate {
  id            String   @id @default(uuid()) @db.Uuid
  time          DateTime @db.Timestamptz
  sourceId      String   @map("source_id") @db.Uuid
  pair          String   @default("USDVND")
  rate          Decimal  @db.Decimal(18, 6)
  rawPayload    Json?    @map("raw_payload")
  qualityScore  Decimal  @default(100) @map("quality_score") @db.Decimal(5, 2)
  isValid       Boolean  @default(true) @map("is_valid")
  invalidReason String?  @map("invalid_reason")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  source        Source   @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, pair, time])
  @@index([pair, time(sort: Desc)])
  @@index([sourceId, time(sort: Desc)])
  @@index([isValid, time(sort: Desc)])
  @@map("fx_rates")
}

model MacroIndicator {
  id            String   @id @default(uuid()) @db.Uuid
  time          DateTime @db.Timestamptz
  sourceId      String   @map("source_id") @db.Uuid
  code          String
  value         Decimal  @db.Decimal(18, 6)
  unit          String
  rawPayload    Json?    @map("raw_payload")
  qualityScore  Decimal  @default(100) @map("quality_score") @db.Decimal(5, 2)
  isValid       Boolean  @default(true) @map("is_valid")
  invalidReason String?  @map("invalid_reason")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  source        Source   @relation(fields: [sourceId], references: [id])

  @@unique([sourceId, code, time])
  @@index([code, time(sort: Desc)])
  @@index([sourceId, time(sort: Desc)])
  @@index([isValid, time(sort: Desc)])
  @@map("macro_indicators")
}

model GoldMetric {
  id                    String      @id @default(uuid()) @db.Uuid
  time                  DateTime    @db.Timestamptz
  productId             String      @map("product_id") @db.Uuid
  domesticBuyPriceVnd   Decimal     @map("domestic_buy_price_vnd") @db.Decimal(18, 2)
  domesticSellPriceVnd  Decimal     @map("domestic_sell_price_vnd") @db.Decimal(18, 2)
  xauUsdPerOz           Decimal     @map("xau_usd_per_oz") @db.Decimal(18, 6)
  usdVnd                Decimal     @map("usd_vnd") @db.Decimal(18, 6)
  worldVndPerLuong      Decimal     @map("world_vnd_per_luong") @db.Decimal(18, 2)
  premiumBuyPct         Decimal     @map("premium_buy_pct") @db.Decimal(12, 8)
  premiumSellPct        Decimal     @map("premium_sell_pct") @db.Decimal(12, 8)
  spreadAbsVnd          Decimal     @map("spread_abs_vnd") @db.Decimal(18, 2)
  spreadPct             Decimal     @map("spread_pct") @db.Decimal(12, 8)
  premiumPercentile180d Decimal?    @map("premium_percentile_180d") @db.Decimal(8, 4)
  spreadPercentile180d  Decimal?    @map("spread_percentile_180d") @db.Decimal(8, 4)
  xauMomentum7d         Decimal?    @map("xau_momentum_7d") @db.Decimal(12, 8)
  xauMomentum30d        Decimal?    @map("xau_momentum_30d") @db.Decimal(12, 8)
  domesticMomentum7d    Decimal?    @map("domestic_momentum_7d") @db.Decimal(12, 8)
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz
  product               GoldProduct @relation(fields: [productId], references: [id])

  @@unique([productId, time])
  @@index([productId, time(sort: Desc)])
  @@map("gold_metrics")
}

model SignalSnapshot {
  id         String      @id @default(uuid()) @db.Uuid
  time       DateTime    @db.Timestamptz
  productId  String      @map("product_id") @db.Uuid
  signal     String
  score      Decimal     @db.Decimal(8, 4)
  confidence Decimal     @db.Decimal(8, 4)
  reasons    Json
  metrics    Json
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz
  product    GoldProduct @relation(fields: [productId], references: [id])

  @@unique([productId, time])
  @@index([productId, time(sort: Desc)])
  @@index([signal, time(sort: Desc)])
  @@map("signal_snapshots")
}

model User {
  id                    String                 @id @default(uuid()) @db.Uuid
  email                 String?                @unique
  name                  String?
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz
  portfolioTransactions PortfolioTransaction[]

  @@map("users")
}

model PortfolioTransaction {
  id               String      @id @default(uuid()) @db.Uuid
  userId           String      @map("user_id") @db.Uuid
  productId        String      @map("product_id") @db.Uuid
  type             String
  quantityLuong    Decimal     @map("quantity_luong") @db.Decimal(18, 6)
  priceVndPerLuong Decimal     @map("price_vnd_per_luong") @db.Decimal(18, 2)
  feeVnd           Decimal     @default(0) @map("fee_vnd") @db.Decimal(18, 2)
  transactionDate  DateTime    @map("transaction_date") @db.Date
  note             String?
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz
  user             User        @relation(fields: [userId], references: [id])
  product          GoldProduct @relation(fields: [productId], references: [id])

  @@index([userId, transactionDate(sort: Desc)])
  @@index([productId, transactionDate(sort: Desc)])
  @@map("portfolio_transactions")
}

model AdminAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz
  actor      String
  action     String
  outcome    String
  requestId  String?  @map("request_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json?

  @@index([occurredAt(sort: Desc)])
  @@index([actor, occurredAt(sort: Desc)])
  @@index([action, occurredAt(sort: Desc)])
  @@map("admin_audit_logs")
}

model SiteAccessLog {
  id         String   @id @default(uuid()) @db.Uuid
  accessedAt DateTime @default(now()) @map("accessed_at") @db.Timestamptz
  ipAddress  String   @map("ip_address")
  path       String?
  userAgent  String?  @map("user_agent")

  @@index([accessedAt(sort: Desc)])
  @@index([ipAddress, accessedAt(sort: Desc)])
  @@map("site_access_logs")
}
